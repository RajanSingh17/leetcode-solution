class Solution {
public:
    int removeDuplicates(vector<int>& nums) {
        int n = nums.size();
        int k = 1;
        for (int i = 1; i < n; i++) {
            int curr = nums[i];
            int prev = nums[i - 1];
            if (curr != prev) {
                nums[k] = curr;
                k++;
            }
        }
        return k;
    }
};
